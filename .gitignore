# ── Python ────────────────────────────────────────────
myenv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Environment variables (NEVER commit these) ────────
.env
.env.local
.env.development
.env.staging
.env.production

# ── FastAPI / Uvicorn ─────────────────────────────────
*.log

# ── Node / React / TypeScript ─────────────────────────
node_modules/
frontend/node_modules/
dist/
frontend/dist/
.npm

# ── Vite ──────────────────────────────────────────────
*.local
frontend/.vite/

# ── TypeScript ────────────────────────────────────────
*.tsbuildinfo
frontend/tsconfig.tsbuildinfo

# ── Database ──────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── OS files ──────────────────────────────────────────
.DS_Store           # Mac
Thumbs.db           # Windows
desktop.ini         # Windows

# ── VS Code ───────────────────────────────────────────
.vscode/*
!.vscode/settings.json      # keep — shared editor settings
!.vscode/extensions.json    # keep — recommends extensions to teammates
!.vscode/launch.json        # keep — debugger config

# ── Testing ───────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Misc ──────────────────────────────────────────────
*.pem               # certificates / keys
*.key
uploads/            # user uploaded files